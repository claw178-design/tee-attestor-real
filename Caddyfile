# Caddy TLS reverse proxy for TEE Attestor
#
# EigenCompute exposes port 8080 externally.
# tls-keygen pre-obtains certs to /run/tls/.
# Caddy serves HTTPS on :8080 using those certs, proxying to Node.js on APP_PORT.

{
	https_port 8080
	http_port 80
}

{$DOMAIN:localhost} {
	tls /run/tls/fullchain.pem /run/tls/privkey.pem

	reverse_proxy localhost:{$APP_PORT:3000} {
		header_up X-Real-IP {remote_host}
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	log {
		output stdout
		format console
		level INFO
	}
}
