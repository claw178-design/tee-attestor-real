PRIVATE_KEY=0x38fa54ed5673f9b3d778863af93708810af676468f5bd5f37f3237da78e555a3

# TOPRF keys (for OPRF hash computation)
TOPRF_PUBLIC_KEY=0x147fee51dfd757dbc476177018cdff28c8932fd94f7adcd5d007779db0d0ca81
TOPRF_SHARE_PUBLIC_KEY=0x147fee51dfd757dbc476177018cdff28c8932fd94f7adcd5d007779db0d0ca81
TOPRF_SHARE_PRIVATE_KEY=0x03ffed1cfbc83b4dbf391a8a22d515764661f3a0477b0c201bf4bed540f0e3b1

# Server config
PORT=8001
NODE_ENV=production
DISABLE_BGP_CHECKS=1
LOG_LEVEL=info
