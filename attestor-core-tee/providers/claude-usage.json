{
  "name": "http",
  "params": {
    "url": "https://api.anthropic.com/v1/messages",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json",
      "anthropic-version": "2023-06-01"
    },
    "body": "{\"model\":\"{{model}}\",\"max_tokens\":256,\"messages\":[{\"role\":\"user\",\"content\":\"{{prompt}}\"}]}",
    "responseMatches": [
      {
        "type": "regex",
        "value": "\"output_tokens\":(?<outputTokens>\\d+)"
      },
      {
        "type": "regex",
        "value": "\"model\":\"(?<modelUsed>[^\"]+)\""
      }
    ],
    "responseRedactions": [
      {
        "jsonPath": "$.usage",
        "regex": "\"usage\":\\{[^}]+\\}",
        "xPath": ""
      },
      {
        "jsonPath": "$.content[0].text",
        "regex": "\"text\":\"([^\"]+)\"",
        "xPath": ""
      }
    ]
  },
  "secretParams": {
    "headers": {
      "x-api-key": "{{apiKey}}"
    }
  }
}
