# tee-attestor-real — Environment Variables
# Copy to .env and fill in your keys

# LLM API Keys (at least one required for integration tests)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Custom attestor WebSocket URL (optional — defaults to Reclaim public attestor)
# ATTESTOR_URL=wss://attestor.reclaimprotocol.org

# Owner private key for signing claims (optional — auto-generated if not set)
# OWNER_PRIVATE_KEY=0x...
