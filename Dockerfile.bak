# TEE Attestor Real — Production Dockerfile
# Runs the signing server inside a TEE (EigenCompute / SGX / TDX)
#
# Build:
#   docker build -t ghcr.io/claw178-design/tee-attestor-real:latest .
#
# Run (standalone TEE signing server):
#   docker run -p 8767:8767 -e TEE_MEASUREMENT=<hash> ghcr.io/claw178-design/tee-attestor-real:latest
#
# Run (proxy + TEE together):
#   docker run -p 8766:8766 -p 8767:8767 ghcr.io/claw178-design/tee-attestor-real:latest node dist/entrypoint.js

FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json* ./
# Strip local file:// deps that don't exist in container context
RUN node -e "const p=require('./package.json'); \
  if(p.dependencies) Object.keys(p.dependencies).forEach(k => { \
    if(String(p.dependencies[k]).startsWith('file:')) delete p.dependencies[k]; \
  }); \
  require('fs').writeFileSync('./package.json', JSON.stringify(p,null,2));"
RUN npm install --ignore-scripts 2>/dev/null || true

COPY tsconfig.json ./
COPY src/ ./src/

# Only compile tee-server and its deps (skip files that import attestor-core)
RUN npx tsc || true

# ─── Production stage ─────────────────────────────────────────────
FROM node:22-alpine

WORKDIR /app

RUN addgroup -S attestor && adduser -S attestor -G attestor

COPY --from=builder /app/dist/ ./dist/
COPY --from=builder /app/node_modules/ ./node_modules/
COPY --from=builder /app/package.json ./

# TEE key directory (persistent volume mount recommended)
RUN mkdir -p /app/.tee-keys && chown attestor:attestor /app/.tee-keys

# Claims directory
RUN mkdir -p /app/claims && chown attestor:attestor /app/claims

USER attestor

# Environment defaults (8080 = EigenCompute standard port)
ENV TEE_ATTESTOR_PORT=8080
ENV TEE_KEY_DIR=/app/.tee-keys
ENV TEE_TYPE=eigencompute
ENV CLAIMS_DIR=/app/claims
ENV NODE_ENV=production

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s \
  CMD wget -qO- http://127.0.0.1:8080/health || exit 1

CMD ["node", "dist/tee-server.js"]
